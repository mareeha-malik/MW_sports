{
  "compilerOptions": {
    "jsx": "preserve",
    "moduleResolution": "bundler",
    "baseUrl": "./",
    "paths": {
      "@/*": [
        "src/*"
      ],
      "@Components/*": [
        "src/app/Components/*"
      ],
      "@lib/*": [
        "src/lib/*"
      ]
    },
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "src/app/utils/api.js",
    "src/app/Components/AddBlogModal.jsx",
    "src/app/Components/ui/AddProductModal.tsx",
    "src/app/Components/ui/card.tsx"
  ],
  "exclude": [
    "node_modules"
  ]
}
